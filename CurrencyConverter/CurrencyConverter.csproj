<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net9.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <Compile Remove="Extentions.cs" />
  </ItemGroup>

  <ItemGroup>
    <Compile Update="ValCurs.Designer.cs">
      <DesignTime>True</DesignTime>
      <AutoGen>True</AutoGen>
      <DependentUpon>ValCurs.xsd</DependentUpon>
    </Compile>
  </ItemGroup>

  <ItemGroup>
    <None Update="ValCurs.xsd">
      <Generator>XsdCodeGenerator</Generator>
      <LastGenOutput>ValCurs.Designer.cs</LastGenOutput>
    </None>
  </ItemGroup>

</Project>
